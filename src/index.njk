  .news-grid { grid-template-columns: 1fr; gap: 24px; }
  .home-mid-grid { grid-template-columns: 1fr; gap: 60px; }
  .team-strip { grid-template-columns: 1fr 1fr; gap: 32px; }
  .milestones-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
}

@media (max-width: 640px) {
  .hero, .section, .author-spotlight, .submissions { padding: 60px 20px; }
  .lab-feature, .mission, .news, .reading-room, .home-mid, .team-section, .milestones { padding: 70px 20px; }
  .hero h1 { font-size: 48px; }
  .submissions-stats { padding: 32px 24px; }
  .submissions-stats dl { grid-template-columns: 1fr; gap: 24px; }
  .author-body h3 { font-size: 36px; }
  .article-card.featured h3 { font-size: 28px; }
  .team-strip { grid-template-columns: 1fr; gap: 24px; }
  .milestones-grid { grid-template-columns: 1fr; gap: 20px; }
  .excerpt-block { padding: 40px 24px; }
}
</style>

<!-- HERO -->
<section class="hero">
  <div class="hero-grid">
    <div class="hero-text">
      <div class="hero-eyebrow">{{ homepage.hero_eyebrow }}</div>
      <h1>{{ homepage.hero_headline | safe }}</h1>
      <p class="lede">{{ homepage.hero_description }}</p>
      <div class="hero-actions">
        <a href="#catalog" class="btn btn-primary">Browse The Catalog <span class="arrow">→</span></a>
        <a href="#submissions" class="btn btn-ghost">Submit Your Work</a>
      </div>
    </div>

    <div class="hero-feature">
      <div class="hero-feature-label">Now Reading</div>
      <h3>{{ homepage.now_reading_title | safe }}</h3>
      <p class="issue">{{ homepage.now_reading_issue }}</p>
      <p>{{ homepage.now_reading_desc }}</p>
      <div class="deadline">
        <span>Reading Through</span>
        <strong>{{ homepage.now_reading_deadline }}</strong>
      </div>
      <a href="#submissions" class="small-link">Submission Guidelines</a>
    </div>
  </div>
</section>

<!-- CATALOG -->
<section class="section new-notable fade-in" id="catalog">
  <div class="section-label">Available Now</div>
  <h2 class="section-title">{{ homepage.catalog_heading | safe }}</h2>
  <p class="section-sub">{{ homepage.catalog_sub }}</p>

  <div class="titles-grid">
    {% for book in catalog %}{% if book.in_catalog %}
    <a href="{{ book.page_link }}" class="title-card">
      <div class="title-cover">
        {% if book.cover_style == 'image' and book.cover_image %}
          <img src="{{ book.cover_image }}" alt="{{ book.title }}">
        {% elif book.cover_style == 'keene' %}
          <div class="cover-keene">
            <div class="label-top">A Novel</div>
            <div class="title">
              <span class="t-small">The Casual</span>
              <span class="t-big">Oblivion</span>
              <span class="t-small">of Francis Keene</span>
            </div>
            <div class="ornament">❦</div>
            <div class="author">M. Patrick Furry</div>
          </div>
        {% elif book.cover_style == 'lab' %}
          <div class="cover-lab">
            <div class="lab-top">
              <span>N°1</span>
              <span>Annual · 2026</span>
            </div>
            <div class="lab-title">The Lab<span class="dot">.</span></div>
            <div class="lab-tagline">An annual of short fiction by independent writers.</div>
            <div class="lab-contents">
              <strong>In Development</strong>
              Forthcoming Fall 2026 — featuring selected work from open submissions, plus original essays and a featured excerpt.
            </div>
          </div>
        {% endif %}
      </div>
      <div class="title-format">{{ book.format }}</div>
      <h3 class="title-name">{{ book.title_html | safe }}</h3>
      <p class="title-author">{{ book.author }}</p>
      <p class="title-desc">{{ book.description }}</p>
      <div class="shelf-talk">
        <strong>Shelf Talk</strong>
        "{{ book.shelf_talk }}" — {{ book.shelf_talk_by }}
      </div>
      <span class="title-link">Read more</span>
    </a>
    {% endif %}{% endfor %}
  </div>
</section>

<!-- NYT RECOMMENDED READING -->
<section class="section" id="recommended" style="border-top: 1px solid var(--rule); padding-top: 60px; padding-bottom: 60px;">
  <div class="section-label">Recommended Reading</div>
  <h2 class="section-title">The <em>New York Times</em> 10 Best Books of 2026, So Far.</h2>
  <p class="section-sub">Selected by the Times Book Review staff — titles we're reading, talking about, and pressing into people's hands.</p>

  <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; margin-top: 40px;">
    {% for book in catalog %}{% if book.nyt_best %}
    <a href="{{ book.page_link }}" class="news-card" target="_blank" rel="noopener" style="text-decoration:none;">
      <div class="news-date">{{ book.format }}</div>
      <h4 style="font-size:19px; margin-bottom:6px;">{{ book.title_html | safe }}</h4>
      <p style="font-family:var(--font-display); font-style:italic; font-size:14px; color:var(--ink-muted); margin-bottom:10px;">{{ book.author }}</p>
      <p style="font-size:13px; line-height:1.5; color:var(--ink-muted); margin-bottom:14px;">{{ book.description }}</p>
      <span class="read-more">Find it at Bookshop</span>
    </a>
    {% endif %}{% endfor %}
  </div>
  <p style="margin-top:24px; font-family:var(--font-ui); font-size:11px; color:var(--ink-faint); letter-spacing:0.15em; text-transform:uppercase;">Bookshop links support independent bookstores.</p>
</section>

<!-- READING ROOM -->
<section class="reading-room fade-in" id="reading-room">
  <div class="reading-room-inner">
    <div class="reading-room-header">
      <div>
        <div class="section-label">The Reading Room</div>
        <h2 class="section-title">Essays, notes, and <em>dispatches</em> from the press.</h2>
      </div>
      <a href="/#reading-room" class="view-all">All Articles</a>
    </div>

    <div class="articles-grid">
      {% for article in articles %}
      <a href="{{ article.link }}" class="article-card{% if article.featured %} featured{% endif %}">
        <div class="article-image article-image-{% if article.image_style == 'play' %}1{% elif article.image_style == 'infinity' %}2{% else %}4{% endif %}"></div>
        <div class="article-category">{{ article.category }} · {{ article.reading_time }}</div>
        <h3>{{ article.title | safe }}</h3>
        <div class="article-byline">{{ article.byline }} &middot; {{ article.published | monthYearLong }}</div>
        <p class="article-snippet">{{ article.snippet | safe }}</p>
        <span class="article-read">{% if article.featured %}Read the essay{% else %}Continue reading{% endif %}</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- HOME MID — featured excerpt + currently -->
<section class="home-mid fade-in">
  <div class="home-mid-grid">
    <div class="excerpt-block">
      <div class="excerpt-meta">
        <span class="category">{{ homepage.excerpt_category }}</span>
        <span class="reading-time">{{ homepage.excerpt_reading_time }}</span>
      </div>
      <h3>{{ homepage.excerpt_title | safe }}</h3>
      <div class="excerpt-byline">{{ homepage.excerpt_byline | safe }}</div>
      <blockquote>
        {% for para in homepage.excerpt_body.split("\n\n") %}<p>{{ para | safe }}</p>{% endfor %}
      </blockquote>
      <a href="{{ homepage.excerpt_link }}" class="excerpt-continues">{{ homepage.excerpt_link_text }}</a>
    </div>

    <div class="currently-card">
      <div class="currently-card-inner">
        <div class="currently-label">● Currently</div>
        <h3>{{ homepage.currently_title | safe }}</h3>
        <ul class="currently-list">
          {% for item in homepage.currently_items %}
          <li>
            <span class="when">{{ item.when }}</span>
            <span class="what">{{ item.what | safe }}</span>
          </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- THE LAB. ANNUAL FEATURE -->
<section class="lab-feature fade-in" id="lab">
  <div class="lab-feature-inner">
    <div class="lab-feature-text">
      <div class="section-label">The Lab. <span style="color: rgba(244,237,224,0.3); margin-left: 8px;">N°1</span></div>
      <h2>An annual of <em>independent</em> short fiction.</h2>
      <p><em>The Lab.</em> is our annual publication — short stories, novel excerpts, and prose miscellany from emerging and established independent writers. We read every submission. We pay our writers. We publish work that doesn't quite fit anywhere else.</p>
      <p>Each year's issue is curated by our editorial team and produced as a print volume, with the full contents also available digitally to subscribers.</p>
      <div class="feature-meta">
        <div>Inaugural Issue<strong>N°1 · Annual 2026</strong></div>
        <div>Reading Period<strong>Through January 31</strong></div>
        <div>Publication<strong>Fall 2026</strong></div>
      </div>
      <div class="lab-actions">
        <a href="#submissions" class="btn btn-light">Submit to The Lab. <span class="arrow">→</span></a>
        <a href="/#newsletter" class="btn btn-outline-light">Subscribe</a>
      </div>
    </div>
    <div class="lab-cover-display">
      <div class="cover-lab">
        <div class="lab-top"><span>N°1</span><span>Annual · 2026</span></div>
        <div class="lab-title">The Lab<span class="dot">.</span></div>
        <div class="lab-tagline">An annual of short fiction by independent writers.</div>
        <div class="lab-contents">
          <strong>In Development</strong>
          Forthcoming Fall 2026 — featuring selected work from open submissions, plus original essays and a featured excerpt.
        </div>
      </div>
    </div>
  </div>
</section>

<!-- AUTHOR SPOTLIGHT -->
<section class="author-spotlight fade-in" id="authors">
  <div class="section-label">Author Spotlight</div>
  <div class="author-grid">
    <div class="author-portrait" style="padding:0;overflow:hidden;border:none;background:none;">
      <img src="/assets/mpf-headshot.jpg" alt="M. Patrick Furry" style="width:100%;height:100%;object-fit:cover;object-position:center top;display:block;">
    </div>

    <div class="author-body">
      <h3>The unsettling spaces where <em>reality frays.</em></h3>
      <p>M. Patrick Furry is an author of speculative fiction who explores the unsettling spaces where reality frays. His work creates a blend of grounded, character-driven storytelling, focused on how ordinary people navigate extraordinary terrors and dark wonders.</p>
      <p>His portfolio includes diverse narratives ranging from the dark persistence of childhood imaginary friends to the analog nightmares of <em>Play</em>, his horror novel. His speculative novel <em>The Casual Oblivion of Francis Keene</em> — a story of a lifelong grifter, a final road trip, and a thirteen-year-old who inherits his grandfather's terrible gift — is currently under consideration for film and television adaptation.</p>
      <p>He lives in Novato, California, with his wife, their son, and two dogs.</p>
    </div>
  </div>
</section>

<!-- MISSION -->
<section class="mission fade-in" id="about">
  <div class="mission-inner">
    <div class="section-label">Our Mission</div>
    <blockquote>{{ homepage.mission_text }}</blockquote>
    <div class="mission-attribution">{{ homepage.mission_attribution }}</div>
  </div>
</section>

<!-- MILESTONES -->
<section class="milestones fade-in">
  <div class="milestones-inner">
    <div class="milestones-header">
      <div class="section-label">A Short History</div>
      <h2>The press, <em>so far</em>.</h2>
    </div>
    <div class="milestones-grid">
      {% for m in homepage.milestones %}
      <div class="milestone">
        <div class="dot"></div>
        <div class="year">{{ m.year }}</div>
        <div class="event">{{ m.event | safe }}</div>
        <div class="note">{{ m.note }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- SUBMISSIONS -->
<section class="submissions fade-in" id="submissions">
  <div class="submissions-grid">
    <div class="submissions-body">
      <div class="section-label">Submissions</div>
      <h2>We're <em>reading</em>.</h2>
      <p>{{ homepage.submissions_intro | safe }}</p>
      <p>{{ homepage.submissions_detail | safe }}</p>
      <form action="https://formspree.io/f/team@theyardlab.com" method="POST" id="submit-form" style="margin-top:24px;">
        <input type="hidden" name="_subject" value="Submission — The Yard Lab">
        <div style="display:flex;flex-direction:column;gap:12px;max-width:460px;">
          <input type="text" name="name" placeholder="Your name" required style="padding:12px 16px;border:1px solid var(--paper-edge);background:var(--paper);font-family:var(--font-ui);font-size:14px;color:var(--ink);">
          <input type="email" name="email" placeholder="your@email.com" required style="padding:12px 16px;border:1px solid var(--paper-edge);background:var(--paper);font-family:var(--font-ui);font-size:14px;color:var(--ink);">
          <input type="text" name="title" placeholder="Work title" required style="padding:12px 16px;border:1px solid var(--paper-edge);background:var(--paper);font-family:var(--font-ui);font-size:14px;color:var(--ink);">
          <input type="number" name="wordcount" placeholder="Word count" min="1" style="padding:12px 16px;border:1px solid var(--paper-edge);background:var(--paper);font-family:var(--font-ui);font-size:14px;color:var(--ink);">
          <select name="type" required style="padding:12px 16px;border:1px solid var(--paper-edge);background:var(--paper);font-family:var(--font-ui);font-size:14px;color:var(--ink);">
            <option value="">Type of submission…</option>
            <option>Short Fiction (up to 7,500 words)</option>
            <option>Novel Excerpt (up to 15,000 words)</option>
            <option>Full Manuscript (query first)</option>
          </select>
          <textarea name="bio" placeholder="Brief bio (2–3 sentences)" rows="3" style="padding:12px 16px;border:1px solid var(--paper-edge);background:var(--paper);font-family:var(--font-ui);font-size:14px;color:var(--ink);resize:vertical;"></textarea>
          <button type="submit" class="btn btn-primary" id="submit-btn">Submit <span class="arrow">→</span></button>
        </div>
        <div id="submit-msg" style="margin-top:12px;font-family:var(--font-ui);font-size:13px;line-height:1.6;"></div>
      </form>
    </div>

    <div class="submissions-stats">
      <dl>
        <div><dt>Short Fiction</dt><dd>Up to <em>7,500</em> words</dd></div>
        <div><dt>Novel Excerpts</dt><dd>Up to <em>15,000</em> words</dd></div>
        <div><dt>Full Manuscripts</dt><dd><em>By query</em> first</dd></div>
        <div><dt>Response Time</dt><dd><em>~8</em> weeks</dd></div>
        <div><dt>Reading Fee</dt><dd><em>None</em></dd></div>
        <div><dt>Payment</dt><dd>On <em>acceptance</em></dd></div>
      </dl>
    </div>
  </div>
</section>

<!-- TEAM -->
<section class="team-section fade-in">
  <div class="section-label">Editorial Board</div>
  <h2>The people <em>behind</em> the press.</h2>
  <div class="team-strip">
    {% for member in team %}
    <div class="team-member">
      <div class="team-monogram">{{ member.monogram }}</div>
      <div class="name">{{ member.name }}</div>
      <div class="role">{{ member.role }}</div>
    </div>
    {% endfor %}
  </div>

</section>

<!-- NEWS -->
<section class="news fade-in">
  <div class="news-inner">
    <div class="section-label">News &amp; Press</div>
    <h2 class="section-title">Announcements <em>from</em> the press.</h2>

    <div class="news-grid">
      {% for item in news %}
      <a href="{{ item.link }}" class="news-card">
        <div class="news-date">{{ item.date | monthYear }}</div>
        <h4>{{ item.headline | safe }}</h4>
        <p>{{ item.summary | safe }}</p>
        <span class="read-more">{{ item.label }}</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- NEWSLETTER -->
<section class="newsletter fade-in" id="newsletter">
  <div class="newsletter-inner">
    <div class="section-label">From the Press</div>
    <h2>Letters from <em>the lab.</em></h2>
    <p>A monthly dispatch on new books, the annual, open reading periods, and the work behind the work. No spam.</p>
    <form class="newsletter-form" action="https://formspree.io/f/team@theyardlab.com" method="POST" id="newsletter-form">
      <input type="email" name="email" placeholder="your@email.com" required>
      <input type="hidden" name="_subject" value="Newsletter Subscription — The Yard Lab">
      <input type="hidden" name="_next" value="/">
      <button type="submit">Subscribe</button>
    </form>
    <div class="fine-print" id="newsletter-msg"></div>
    <div class="fine-print">Unsubscribe at any time</div>
  </div>
</section>

<script>
// Submission form
(function() {
  var form = document.getElementById('submit-form');
  if (!form) return;
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var btn = document.getElementById('submit-btn');
    var msg = document.getElementById('submit-msg');
    btn.textContent = 'Sending…';
    btn.disabled = true;
    fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    }).then(function(r) {
      if (r.ok) {
        btn.textContent = '✓ Details received!';
        msg.innerHTML = 'Thanks — one last step: email your manuscript as a <strong>.docx or .pdf</strong> to <a href="mailto:team@theyardlab.com?subject=Manuscript%20Attached" style="color:var(--oxblood);border-bottom:1px solid var(--oxblood);">team@theyardlab.com</a> with your name and title in the subject line. We respond to every submission within 8 weeks.';
        msg.style.color = 'var(--ink)';
        form.reset();
      } else {
        btn.textContent = 'Submit →';
        btn.disabled = false;
        msg.textContent = 'Something went wrong. Email us directly at team@theyardlab.com.';
      }
    }).catch(function() {
      btn.textContent = 'Submit →';
      btn.disabled = false;
      msg.textContent = 'Something went wrong. Email us directly at team@theyardlab.com.';
    });
  });
})();

// Newsletter form
(function() {
  var form = document.getElementById('newsletter-form');
  if (!form) return;
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var btn = form.querySelector('button');
    var msg = document.getElementById('newsletter-msg');
    btn.textContent = 'Sending…';
    btn.disabled = true;
    fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    }).then(function(r) {
      if (r.ok) {
        btn.textContent = '✓ Subscribed!';
        msg.textContent = 'Thanks — check your inbox for a confirmation.';
        form.reset();
      } else {
        btn.textContent = 'Subscribe';
        btn.disabled = false;
        msg.textContent = 'Something went wrong. Email us at team@theyardlab.com.';
      }
    }).catch(function() {
      btn.textContent = 'Subscribe';
      btn.disabled = false;
      msg.textContent = 'Something went wrong. Email us at team@theyardlab.com.';
    });
  });
})();
