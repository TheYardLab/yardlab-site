<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title or settings.site_name }}</title>
<meta name="description" content="{{ description or settings.tagline }}">
<link rel="icon" type="image/png" href="/assets/favicon.png">
<link rel="stylesheet" href="/styles.css">
{% block head %}{% endblock %}
</head>
<body>

<!-- ANNOUNCEMENT -->
<div class="announce">
  <span class="pin">●</span>
  {{ settings.announcement_text | safe }} &nbsp; <a href="{{ settings.announcement_link_url }}">{{ settings.announcement_link_text }} →</a>
</div>

<!-- HEADER -->
<header class="header">
  <div class="header-inner">
    <a href="/" class="logo">
      <img src="/assets/yardlab-icon.png" alt="The Yard Lab" class="logo-mark">
      <span class="logo-text">
        <span class="logo-name">The Yard Lab<span class="ampersand">.</span></span>
        <span class="logo-sub">Publishing Group · Est. {{ settings.founded_year }}</span>
      </span>
    </a>
    <nav class="primary">
      <a href="/#catalog"{% if active_nav == 'catalog' %} class="active"{% endif %}>Catalog</a>
      <a href="/#lab"{% if active_nav == 'lab' %} class="active"{% endif %}>The Lab.</a>
      <a href="/#reading-room"{% if active_nav == 'reading' %} class="active"{% endif %}>Reading Room</a>
      <a href="/#authors"{% if active_nav == 'authors' %} class="active"{% endif %}>Authors</a>
      <a href="/#submissions"{% if active_nav == 'submissions' %} class="active"{% endif %}>Submissions</a>
      <a href="/#about"{% if active_nav == 'about' %} class="active"{% endif %}>About</a>
    </nav>
    <div class="header-actions">
      <a href="#" aria-label="Search">
        <svg class="search-icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21"/></svg>
      </a>
      <a href="/#newsletter">Subscribe</a>
    </div>
  </div>
</header>

{{ content | safe }}

<!-- FOOTER -->
<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <img src="/assets/yardlab-logo-full-light.png" alt="The Yard Lab Publishing Group" class="footer-logo-image">
        <p>{{ settings.tagline | safe }}</p>
      </div>

      <div class="footer-col">
        <h5>Catalog</h5>
        <ul>
          {% for book in catalog %}
          <li><a href="{{ book.page_link }}">{{ book.title }}</a></li>
          {% endfor %}
          <li><a href="/#lab">Forthcoming: The Lab. Annual</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h5>The Lab.</h5>
        <ul>
          <li><a href="/#lab">About the Annual</a></li>
          <li><a href="/#submissions">Submit</a></li>
          <li><a href="/#newsletter">Subscribe</a></li>
          <li><a href="/#reading-room">Reading Room</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h5>The Press</h5>
        <ul>
          <li><a href="/#about">About</a></li>
          <li><a href="/#submissions">Submissions</a></li>
          <li><a href="/#authors">Authors</a></li>
          <li><a href="/#reading-room">Reading Room</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h5>Connect</h5>
        <ul>
          <li><a href="/#newsletter">Newsletter</a></li>
          {% if settings.instagram_url %}<li><a href="{{ settings.instagram_url }}">Instagram</a></li>{% endif %}
          {% if settings.bluesky_url %}<li><a href="{{ settings.bluesky_url }}">Bluesky</a></li>{% endif %}
          <li><a href="mailto:{{ settings.contact_email }}">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="colophon">Set in Cormorant Garamond &amp; EB Garamond. Printed in California.</div>
      <div class="footer-bottom-links">
        <a href="mailto:team@theyardlab.com?subject=Privacy%20Inquiry">Privacy</a>
        <a href="mailto:team@theyardlab.com?subject=Terms%20Inquiry">Terms</a>
        <a href="#">© 2026 The Yard Lab Publishing Group, LLC</a>
      </div>
    </div>
  </div>
</footer>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.08 });
  document.querySelectorAll('.fade-in').forEach(el => io.observe(el));
  setTimeout(() => {
    document.querySelectorAll('.fade-in:not(.visible)').forEach(el => el.classList.add('visible'));
  }, 4000);
</script>


<!-- Cookie consent banner -->
<div id="cookie-banner" class="cookie-banner" hidden>
  <div class="cookie-banner-inner">
    <p class="cookie-text">
      This site uses essential cookies for form submissions and basic functionality. We do not use tracking, analytics, or advertising cookies. <a href="/privacy/">Privacy policy</a>.
    </p>
    <div class="cookie-actions">
      <button type="button" class="cookie-btn cookie-decline" id="cookie-decline">Decline</button>
      <button type="button" class="cookie-btn cookie-accept" id="cookie-accept">Accept</button>
    </div>
  </div>
</div>

<style>
.cookie-banner {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--ink); color: var(--paper);
  border-top: 1px solid var(--gold);
  padding: 20px 40px; z-index: 1000;
  font-family: var(--font-ui);
  box-shadow: 0 -8px 24px rgba(0,0,0,0.18);
  transform: translateY(100%);
  transition: transform 0.45s ease;
}
.cookie-banner.visible { transform: translateY(0); }
.cookie-banner-inner {
  max-width: 1400px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  gap: 32px; flex-wrap: wrap;
}
.cookie-text {
  font-size: 13px; line-height: 1.55;
  color: rgba(244,237,224,0.85); margin: 0;
  max-width: 760px;
}
.cookie-text a {
  color: var(--gold);
  border-bottom: 1px solid rgba(184,153,104,0.4);
  text-decoration: none;
}
.cookie-text a:hover { border-bottom-color: var(--gold); }
.cookie-actions { display: flex; gap: 12px; }
.cookie-btn {
  font-family: var(--font-ui); font-size: 11px; font-weight: 600;
  letter-spacing: 0.2em; text-transform: uppercase;
  padding: 10px 20px; cursor: pointer;
  border: 1px solid var(--paper); background: transparent; color: var(--paper);
  transition: all 0.2s;
}
.cookie-accept { background: var(--paper); color: var(--ink); }
.cookie-accept:hover { background: var(--gold); border-color: var(--gold); color: var(--ink); }
.cookie-decline:hover { border-color: var(--gold); color: var(--gold); }
@media (max-width: 640px) {
  .cookie-banner { padding: 16px 20px; }
  .cookie-banner-inner { gap: 16px; }
  .cookie-actions { width: 100%; }
  .cookie-btn { flex: 1; }
}
</style>

<script>
(function() {
  var KEY = 'yardlab-cookie-consent';
  var banner = document.getElementById('cookie-banner');
  if (!banner) return;
  var stored = null;
  try { stored = localStorage.getItem(KEY); } catch(e) {}
  if (stored === 'accepted' || stored === 'declined') return;
  banner.hidden = false;
  requestAnimationFrame(function() { banner.classList.add('visible'); });
  function dismiss(choice) {
    try { localStorage.setItem(KEY, choice); } catch(e) {}
    banner.classList.remove('visible');
    setTimeout(function() { banner.hidden = true; }, 450);
  }
  document.getElementById('cookie-accept').addEventListener('click', function() { dismiss('accepted'); });
  document.getElementById('cookie-decline').addEventListener('click', function() { dismiss('declined'); });
})();
</script>

</body>
</html>
